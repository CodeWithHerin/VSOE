generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Journey {
  id          String   @id @default(uuid())
  name        String   // e.g., "Paris to Venice"
  departure   DateTime
  arrival     DateTime
  status      String   // "scheduled", "completed", "cancelled"
  
  segments    RouteSegment[]
  buckets     InventoryBucket[]
  bookings    Booking[]
}

model RouteSegment {
  id          String   @id @default(uuid())
  journeyId   String
  journey     Journey  @relation(fields: [journeyId], references: [id])
  
  origin      String
  destination String
  departure   DateTime
  arrival     DateTime
  order       Int      // 0, 1, 2... sequence in journey
  
  buckets     InventoryBucket[]
}

model TrainCar {
  id          String   @id @default(uuid())
  name        String   // e.g., "L'Oriental"
  type        String   // "sleeping", "dining", "bar"
  
  cabins      Cabin[]
}

model Cabin {
  id          String   @id @default(uuid())
  carId       String
  car         TrainCar @relation(fields: [carId], references: [id])
  
  number      String   // e.g., "A1"
  type        String   // "grand_suite", "suite", "historic"
  capacity    Int
  
  buckets     InventoryBucket[]
  passengers  Passenger[]
}

model InventoryBucket {
  id          String   @id @default(uuid())
  
  journeyId   String
  journey     Journey  @relation(fields: [journeyId], references: [id])
  
  segmentId   String
  segment     RouteSegment @relation(fields: [segmentId], references: [id])
  
  cabinId     String
  cabin       Cabin    @relation(fields: [cabinId], references: [id])
  
  status      String   // "available", "held", "booked", "maintenance"
  price       Float
  currency    String   @default("EUR")
  
  @@unique([journeyId, segmentId, cabinId])
}

model Booking {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  
  // Contact Info
  firstName   String
  lastName    String
  email       String
  phone       String?
  
  // Journey Details
  journeyId   String
  journey     Journey  @relation(fields: [journeyId], references: [id])
  
  // Financials
  totalPrice  Float
  currency    String   @default("EUR")
  status      String   // "pending", "confirmed", "cancelled"
  
  // Relations
  passengers  Passenger[]
}

model Passenger {
  id          String   @id @default(uuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id])
  
  firstName   String
  lastName    String
  passport    String?
  
  cabinId     String
  cabin       Cabin    @relation(fields: [cabinId], references: [id])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed
  name      String?
  createdAt DateTime @default(now())
}
